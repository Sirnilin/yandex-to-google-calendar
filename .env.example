# Environment variables for Yandex to Google Calendar sync

# Yandex Calendar Credentials (REQUIRED)
YANDEX_USERNAME=your_yandex_email@yandex.ru
YANDEX_PASSWORD=your_app_password

# Yandex CalDAV URL (optional, default shown)
YANDEX_CALDAV_URL=https://caldav.yandex.ru

# Google Calendar Settings
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=data/credentials.json
GOOGLE_TOKEN_FILE=data/token.json

# Sync Configuration
SYNC_INTERVAL_MINUTES=30
DAYS_AHEAD=30
DAYS_BEHIND=7

# State Management
STATE_FILE=data/sync_state.json

# Logging
LOG_LEVEL=INFO